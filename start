#!/usr/bin/env sh
set -eu

SCHEME="http"
CERT_DIR=".cert"
CERT_KEY="$CERT_DIR/visual-visual.key"
CERT_CERT="$CERT_DIR/visual-visual.crt"
CERT_CONFIG="$CERT_DIR/visual-visual.openssl.cnf"
CERT_HOSTS_FILE="$CERT_DIR/visual-visual.hosts"
HTTPS_ENABLED=0

LAN_IP=""
if command -v ipconfig >/dev/null 2>&1; then
  LAN_IP="$(ipconfig getifaddr en0 2>/dev/null || true)"
fi
if [ -z "$LAN_IP" ] && command -v hostname >/dev/null 2>&1; then
  LAN_IP="$(hostname -I 2>/dev/null | awk '{print $1}' || true)"
fi

CERT_HOSTS="localhost 127.0.0.1 ::1"
if [ -n "$LAN_IP" ]; then
  CERT_HOSTS="$CERT_HOSTS $LAN_IP"
fi

if command -v openssl >/dev/null 2>&1; then
  mkdir -p "$CERT_DIR"
  CURRENT_CERT_HOSTS=""
  if [ -f "$CERT_HOSTS_FILE" ]; then
    CURRENT_CERT_HOSTS="$(cat "$CERT_HOSTS_FILE")"
  fi

  if [ ! -f "$CERT_KEY" ] || [ ! -f "$CERT_CERT" ] || [ "$CURRENT_CERT_HOSTS" != "$CERT_HOSTS" ]; then
    {
      printf '[req]\n'
      printf 'distinguished_name = dn\n'
      printf 'x509_extensions = v3_req\n'
      printf 'prompt = no\n'
      printf '\n[dn]\n'
      printf 'CN = visual-visual.local\n'
      printf '\n[v3_req]\n'
      printf 'subjectAltName = @alt_names\n'
      printf 'keyUsage = critical, digitalSignature, keyEncipherment\n'
      printf 'extendedKeyUsage = serverAuth\n'
      printf '\n[alt_names]\n'
      printf 'DNS.1 = localhost\n'
      printf 'IP.1 = 127.0.0.1\n'
      printf 'IP.2 = ::1\n'
      if [ -n "$LAN_IP" ]; then
        printf 'IP.3 = %s\n' "$LAN_IP"
      fi
    } > "$CERT_CONFIG"

    if openssl req -x509 -newkey rsa:2048 -sha256 -days 825 -nodes \
      -keyout "$CERT_KEY" \
      -out "$CERT_CERT" \
      -config "$CERT_CONFIG" >/dev/null 2>&1; then
      printf '%s' "$CERT_HOSTS" > "$CERT_HOSTS_FILE"
    else
      printf 'Could not generate HTTPS certificate; falling back to HTTP.\n' >&2
      rm -f "$CERT_KEY" "$CERT_CERT"
    fi
  fi

  if [ -f "$CERT_KEY" ] && [ -f "$CERT_CERT" ]; then
    SCHEME="https"
    HTTPS_ENABLED=1
    export VISUAL_VISUAL_HTTPS_KEY="/app/$CERT_KEY"
    export VISUAL_VISUAL_HTTPS_CERT="/app/$CERT_CERT"
  fi
fi

URL="$SCHEME://localhost:5173/"
VIEWER_URL="$SCHEME://localhost:5173/viewer"

cleanup() {
  docker compose down
}

trap cleanup INT TERM EXIT

docker compose up --build &
COMPOSE_PID="$!"

READY=0
if command -v curl >/dev/null 2>&1; then
  i=0
  while [ "$i" -lt 60 ]; do
    CURL_ARGS="-fsS"
    if [ "$HTTPS_ENABLED" -eq 1 ]; then
      CURL_ARGS="-kfsS"
    fi
    if docker compose ps --status running --services | grep -qx web &&
      curl $CURL_ARGS "$URL" >/dev/null 2>&1; then
      READY=1
      break
    fi
    i=$((i + 1))
    sleep 1
  done
else
  sleep 2
  if docker compose ps --status running --services | grep -qx web; then
    READY=1
  fi
fi

if [ "$READY" -eq 1 ]; then
  if command -v open >/dev/null 2>&1; then
    open "$URL"
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$URL" >/dev/null 2>&1 &
  else
    printf 'Open %s in your browser.\n' "$URL"
  fi

  printf '\nVisual Visual host URLs:\n'
  printf '  Editor: %s\n' "$URL"
  printf '  Viewer: %s\n' "$VIEWER_URL"
  if [ -n "$LAN_IP" ]; then
    printf '  Editor for another device: %s://%s:5173/\n' "$SCHEME" "$LAN_IP"
    printf '  Viewer for projector: %s://%s:5173/viewer\n' "$SCHEME" "$LAN_IP"
  fi
  printf '  Note: Vite may print a Docker-internal 172.x network URL above; use the host URLs here.\n'
  if [ "$HTTPS_ENABLED" -eq 1 ]; then
    printf '  HTTPS note: this uses a self-signed certificate in .cert/. Accept or trust it in the browser before using camera/mic over LAN.\n'
  else
    printf '  Camera/mic note: browsers allow capture on localhost, but usually block it on plain HTTP LAN IPs. Install openssl or use HTTPS for projector capture over LAN.\n'
  fi
else
  printf 'Visual Visual did not become ready; browser was not opened.\n' >&2
fi

wait "$COMPOSE_PID"
